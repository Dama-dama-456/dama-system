# ─── مرحلة البناء ───────────────────────────────────────────
FROM node:20 AS builder
WORKDIR /workspace

# تثبيت pnpm
RUN npm install -g pnpm@10

# نسخ ملفات الـ workspace
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml tsconfig.json ./

# نسخ المكتبات المشتركة
COPY lib/ lib/

# نسخ الواجهة الأمامية
COPY artifacts/dama-web/ artifacts/dama-web/

# تثبيت الحزم
RUN pnpm install --no-frozen-lockfile

# بناء الـ frontend (BASE_PATH=/ للنشر على الجذر)
WORKDIR /workspace/artifacts/dama-web
ENV PORT=3000
ENV BASE_PATH=/
ENV NODE_ENV=production
RUN pnpm run build

# ─── مرحلة الخدمة ───────────────────────────────────────────
FROM nginx:1.25-alpine
COPY --from=builder /workspace/artifacts/dama-web/dist/public /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
